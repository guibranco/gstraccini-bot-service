Options -Indexes
RewriteEngine On

# Redirect any domain other than the correct one to api.bot.straccini.com
RewriteCond %{HTTP_HOST} !^api\.bot\.straccini\.com$ [NC]
RewriteRule ^ https://api.bot.straccini.com%{REQUEST_URI} [R=301,L]

# Redirect root to v1/
RewriteRule ^$ /v1/ [R=302,L]

# Allow install.php to be accessed directly (deployment entry point)
RewriteRule ^install\.php$ - [L]

# Redirect any non-existent, non-v1 path to v1/
RewriteCond %{REQUEST_URI} !^/v1(/|$)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /v1/ [R=302,L]
