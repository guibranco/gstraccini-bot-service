Options -Indexes

RewriteEngine On

# Redirect any domain other than the correct one to api.bot.straccini.com
RewriteCond %{HTTP_HOST} !^api\.bot\.straccini\.com$ [NC]
RewriteRule ^ https://api.bot.straccini.com%{REQUEST_URI} [R=301,L]

# Serve openapi.yaml through PHP for version injection (must precede !-f check)
RewriteRule ^openapi\.yaml$ openapi.php [NC,L]

# Redirect routes without trailing slash to canonical form
RewriteRule ^(commands|health|swagger|stats|pending-actions|notifications|recent-activities|profile|preferences|user-settings|integrations)$ /v1/$1/ [R=301,NC,L]
RewriteRule ^jobs/([a-zA-Z]+)$ /v1/jobs/$1/ [R=301,NC,L]
RewriteRule ^pending-actions/([0-9]+)/read$ /v1/pending-actions/$1/read/ [R=301,NC,L]
RewriteRule ^notifications/([0-9]+)/read$ /v1/notifications/$1/read/ [R=301,NC,L]
RewriteRule ^integrations/([^/]+)$ /v1/integrations/$1/ [R=301,NC,L]
RewriteRule ^auth/(login|login/verify-totp|login/verify-recovery|password|totp/setup|totp/enable|totp/disable|totp/status|recovery-codes/generate|password-reset/request|password-reset/verify)$ /v1/auth/$1/ [R=301,NC,L]

# Route trailing-slash requests to PHP handlers
RewriteRule ^commands/$ commands.php [NC,L]
RewriteRule ^health/$ health.php [NC,L]
RewriteRule ^swagger/$ swagger.php [NC,L]
RewriteRule ^stats/$ stats.php [NC,L]
RewriteRule ^jobs/([a-zA-Z]+)/$ jobs.php [NC,L]
RewriteRule ^pending-actions/$ pendingActions.php [NC,L]
RewriteRule ^pending-actions/([0-9]+)/read/$ pendingActions.php [NC,L]
RewriteRule ^notifications/$ notifications.php [NC,L]
RewriteRule ^notifications/([0-9]+)/read/$ notifications.php [NC,L]
RewriteRule ^recent-activities/$ recentActivities.php [NC,L]
RewriteRule ^profile/$ profile.php [NC,L]
RewriteRule ^preferences/$ preferences.php [NC,L]
RewriteRule ^user-settings/$ userSettings.php [NC,L]
RewriteRule ^integrations/$ integrations.php [NC,L]
RewriteRule ^integrations/([^/]+)/$ integrations.php [NC,L]
RewriteRule ^auth/(login|login/verify-totp|login/verify-recovery|password|totp/setup|totp/enable|totp/disable|totp/status|recovery-codes/generate|password-reset/request|password-reset/verify)/$ auth.php [NC,L]
