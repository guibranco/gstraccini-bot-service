[Unit]
Description=GStraccini Bot - Branches Worker
After=network.target mysql.service
Wants=mysql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/gstraccini-bot-service/Src
ExecStart=/usr/bin/php /var/www/gstraccini-bot-service/Src/Workers/branches.php
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=gstraccini-branches
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
